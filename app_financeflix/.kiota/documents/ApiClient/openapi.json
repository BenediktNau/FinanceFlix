{
  "openapi": "3.1.1",
  "info": {
    "title": "FinanceFlix | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/"
    }
  ],
  "paths": {
    "/todos": {
      "get": {
        "tags": [
          "FinanceFlix"
        ],
        "operationId": "GetTodos",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Todo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/todos/{id}": {
      "get": {
        "tags": [
          "FinanceFlix"
        ],
        "operationId": "GetTodoById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/transaction": {
      "get": {
        "tags": [
          "FinanceFlix"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultOfListOfTransaction"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResultOfListOfTransaction": {
        "type": "object",
        "properties": {
          "value": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          },
          "error": {
            "type": [
              "null",
              "string"
            ]
          },
          "isSuccess": {
            "type": "boolean"
          }
        }
      },
      "Todo": {
        "required": [
          "id",
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "dueBy": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "isComplete": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "accountId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "amount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "category": {
            "$ref": "#/components/schemas/TransactionCategory"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TransactionCategory": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "FinanceFlix"
    }
  ]
}